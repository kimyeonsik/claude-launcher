#!/usr/bin/env zsh
# Claude Launcher - Project selector on terminal startup
#
# Install: add to end of ~/.zshrc
#   [[ -f "$HOME/.local/bin/claude-launcher" ]] && source "$HOME/.local/bin/claude-launcher"
#
# Open terminal without launcher:
#   CLAUDE_LAUNCHER_SKIP=1 zsh

_CL_CONFIG_DIR="$HOME/.config/claude-launcher"
_CL_PROJECTS_FILE="$_CL_CONFIG_DIR/projects.json"
_CL_PREVIEW_SCRIPT="$_CL_CONFIG_DIR/preview.sh"
_CL_TIMEOUT=5

# Resolve absolute paths for external commands (independent of PATH at function runtime)
_CL_PYTHON3=$(command -v python3 2>/dev/null)
[[ -z "$_CL_PYTHON3" && -x "/opt/homebrew/bin/python3" ]] && _CL_PYTHON3="/opt/homebrew/bin/python3"
[[ -z "$_CL_PYTHON3" && -x "/usr/local/bin/python3" ]]   && _CL_PYTHON3="/usr/local/bin/python3"
[[ -z "$_CL_PYTHON3" && -x "/usr/bin/python3" ]]          && _CL_PYTHON3="/usr/bin/python3"

_CL_FZF=$(command -v fzf 2>/dev/null)
[[ -z "$_CL_FZF" && -x "/opt/homebrew/bin/fzf" ]] && _CL_FZF="/opt/homebrew/bin/fzf"
[[ -z "$_CL_FZF" && -x "/usr/local/bin/fzf" ]]   && _CL_FZF="/usr/local/bin/fzf"

_CL_SLEEP=$(command -v sleep 2>/dev/null)
[[ -z "$_CL_SLEEP" ]] && _CL_SLEEP="/bin/sleep"

_CL_FIND=$(command -v find 2>/dev/null)
[[ -z "$_CL_FIND" ]] && _CL_FIND="/usr/bin/find"

# ─── Language detection ──────────────────────────────────────────────────────
# Priority: $CLAUDE_LAUNCHER_LANG > config file > $LANG > "en"

_CL_CONFIG_FILE="$_CL_CONFIG_DIR/config"
_CL_LANG_DIR="$_CL_CONFIG_DIR/lang"

_cl_detect_lang() {
  # 1. Env var override
  if [[ -n "$CLAUDE_LAUNCHER_LANG" ]]; then
    echo "$CLAUDE_LAUNCHER_LANG"
    return
  fi
  # 2. Saved config
  if [[ -f "$_CL_CONFIG_FILE" ]]; then
    local saved
    saved=$(grep '^LANG=' "$_CL_CONFIG_FILE" 2>/dev/null | head -1 | cut -d= -f2)
    if [[ -n "$saved" ]]; then
      echo "$saved"
      return
    fi
  fi
  # 3. Auto-detect from $LANG
  case "${LANG:-en}" in
    ko*) echo "ko" ;;
    *)   echo "en" ;;
  esac
}

_CL_LANG=$(_cl_detect_lang)

# Source language file (installed location first, then repo fallback)
if [[ -f "$_CL_LANG_DIR/${_CL_LANG}.sh" ]]; then
  source "$_CL_LANG_DIR/${_CL_LANG}.sh"
elif [[ -f "${0:A:h}/lang/${_CL_LANG}.sh" ]]; then
  source "${0:A:h}/lang/${_CL_LANG}.sh"
else
  # Fallback defaults (English)
  _CL_MSG_MENU_TERMINAL="[→ Normal Terminal]"
  _CL_MSG_MENU_ADD="[+ Add New Project]"
  _CL_MSG_FZF_HEADER=" Claude Code Launcher | Enter:Select  Esc:Exit"
  _CL_MSG_BROWSE_HEADER=" Browse Directories | Type to filter  Enter:Select  Esc:Cancel"
  _CL_MSG_COUNTDOWN_L1="Press any key to open project list."
  _CL_MSG_COUNTDOWN_L2="%d seconds until normal terminal."
  _CL_MSG_COUNTDOWN_TIP="Tip: CLAUDE_LAUNCHER_SKIP=1 zsh to skip"
  _CL_MSG_ADD_TITLE="Add New Project"
  _CL_MSG_ADD_NAME="  Name: "
  _CL_MSG_ADD_NAME_REQ="  Name is required."
  _CL_MSG_ADD_BROWSE="  Browse and select a directory..."
  _CL_MSG_ADD_CANCEL="  Cancelled."
  _CL_MSG_ADD_INVALID="  Invalid path."
  _CL_MSG_ADD_OK="  '%s' added"
  _CL_MSG_ADD_DUP="  Path already registered."
  _CL_MSG_ADD_ERR="  Error: %s"
  _CL_MSG_PATH_ERR="Path not found: '%s'"
  _CL_MSG_NO_PY="Claude Launcher: python3 not found."
  _CL_MSG_NO_FZF="Claude Launcher: fzf is not installed."
  _CL_MSG_NO_FZF_HINT="   Install: brew install fzf"
  _CL_MSG_NO_LAST="none"
  _CL_MSG_PREV_NOPATH="Path not found:"
  _CL_MSG_PREV_TERM="Exit launcher and start terminal in current directory."
  _CL_MSG_PREV_ADD1="Add a new project to the list."
  _CL_MSG_PREV_ADD2="Enter project name and path to save to projects.json."
fi

# ─── Init ────────────────────────────────────────────────────────────────────

_cl_init() {
  mkdir -p "$_CL_CONFIG_DIR"
  [[ -f "$_CL_PROJECTS_FILE" ]] || printf "[]" > "$_CL_PROJECTS_FILE"

  # Generate fzf preview script with current language strings
  cat > "$_CL_PREVIEW_SCRIPT" << PREVIEW_EOF
import sys, os, subprocess

line = sys.stdin.read().strip()
SEP = chr(0x2502)  # │

if SEP in line:
    parts = line.split(SEP)
    path = parts[1].strip() if len(parts) > 1 else ""
    if path and os.path.isdir(path):
        print(f"📁  {path}\n")
        r = subprocess.run(["ls", "-lah", path], capture_output=True, text=True)
        for l in r.stdout.splitlines()[:25]:
            print(l)
    else:
        print(f"⚠️  ${_CL_MSG_PREV_NOPATH} {path!r}")
elif line.startswith("[→"):
    print("💻  ${_CL_MSG_PREV_TERM}")
elif line.startswith("[+"):
    print("➕  ${_CL_MSG_PREV_ADD1}\n")
    print("${_CL_MSG_PREV_ADD2}")
else:
    print(f"▶  {line}")
PREVIEW_EOF
}

# ─── JSON operations (Python3) ───────────────────────────────────────────────

_cl_list_projects() {
  "$_CL_PYTHON3" - "$_CL_PROJECTS_FILE" "$_CL_MSG_NO_LAST" << 'PYEOF'
import json, sys

try:
    with open(sys.argv[1]) as f:
        projects = json.load(f)
    no_last = sys.argv[2] if len(sys.argv) > 2 else "none"
    projects.sort(key=lambda p: p.get("last_used", ""), reverse=True)
    for p in projects:
        name = p.get("name", "?")
        path = p.get("path", "")
        last = p.get("last_used", no_last)
        print(f"{name:<25} \u2502 {path:<50} \u2502 {last}")
except Exception:
    pass
PYEOF
}

_cl_touch_project() {
  local target="$1"
  "$_CL_PYTHON3" - "$_CL_PROJECTS_FILE" "$target" << 'PYEOF'
import json, sys
from datetime import datetime

try:
    with open(sys.argv[1]) as f:
        projects = json.load(f)
    for p in projects:
        if p.get("path") == sys.argv[2]:
            p["last_used"] = datetime.now().strftime("%Y-%m-%dT%H:%M:%S")
    with open(sys.argv[1], "w") as f:
        json.dump(projects, f, indent=2, ensure_ascii=False)
except Exception:
    pass
PYEOF
}

_cl_add_project() {
  local name="$1" path="$2"
  "$_CL_PYTHON3" - "$_CL_PROJECTS_FILE" "$name" "$path" << 'PYEOF'
import json, sys
from datetime import datetime

file, name, path = sys.argv[1], sys.argv[2], sys.argv[3]
try:
    with open(file) as f:
        data = json.load(f)
    for p in data:
        if p.get("path") == path:
            print("DUPLICATE")
            sys.exit(0)
    data.append({
        "name": name,
        "path": path,
        "last_used": datetime.now().strftime("%Y-%m-%dT%H:%M:%S")
    })
    with open(file, "w") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)
    print("OK")
except Exception as e:
    print(f"ERROR:{e}")
PYEOF
}

_cl_remove_project() {
  local target="$1"
  "$_CL_PYTHON3" - "$_CL_PROJECTS_FILE" "$target" << 'PYEOF'
import json, sys

try:
    with open(sys.argv[1]) as f:
        data = json.load(f)
    data = [p for p in data if p.get("path") != sys.argv[2]]
    with open(sys.argv[1], "w") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)
    print("OK")
except Exception as e:
    print(f"ERROR:{e}")
PYEOF
}

# ─── UI ──────────────────────────────────────────────────────────────────────

_cl_pick() {
  local list
  list=$(_cl_list_projects)

  {
    echo "$_CL_MSG_MENU_TERMINAL"
    echo "$_CL_MSG_MENU_ADD"
    [[ -n "$list" ]] && printf "%s\n" "$list"
  } | "$_CL_FZF" \
    --header="$_CL_MSG_FZF_HEADER" \
    --preview="echo {} | \"$_CL_PYTHON3\" \"$_CL_PREVIEW_SCRIPT\"" \
    --preview-window="right:50%:wrap" \
    --height="80%" \
    --border="rounded" \
    --prompt="▶ " \
    --pointer="→" \
    --no-sort \
    --ansi
}

_cl_browse_dir() {
  local start="${1:-$HOME}"
  "$_CL_FIND" "$start" -maxdepth 5 -type d \
    \( -name ".git" -o -name "node_modules" -o -name ".cache" \
       -o -name ".Trash" -o -name "__pycache__" -o -name ".venv" \
       -o -name "venv" -o -name ".hg" \) -prune \
    -o -type d -print 2>/dev/null | \
  "$_CL_FZF" \
    --header="$_CL_MSG_BROWSE_HEADER" \
    --preview="ls -lah {}" \
    --preview-window="right:50%:wrap" \
    --height="80%" \
    --border="rounded" \
    --prompt="📁 " \
    --pointer="→"
}

_cl_handle_add() {
  printf "\n"
  printf "┌─ %s ─────────────────────────────────────────────┐\n" "$_CL_MSG_ADD_TITLE"
  printf "│                                                    │\n"

  local name path

  printf "│%s" "$_CL_MSG_ADD_NAME"
  read -r name < /dev/tty

  if [[ -z "$name" ]]; then
    printf "│  ❌ %s\n" "$_CL_MSG_ADD_NAME_REQ"
    printf "└────────────────────────────────────────────────────┘\n"
    "$_CL_SLEEP" 1
    return 1
  fi

  printf "│  %s\n" "$_CL_MSG_ADD_BROWSE"
  printf "└────────────────────────────────────────────────────┘\n"

  path=$(_cl_browse_dir)

  if [[ -z "$path" ]]; then
    printf "\n  %s\n" "$_CL_MSG_ADD_CANCEL"
    "$_CL_SLEEP" 1
    return 1
  fi

  path=$(cd "$path" 2>/dev/null && pwd)

  if [[ -z "$path" || ! -d "$path" ]]; then
    printf "\n  ❌ %s\n" "$_CL_MSG_ADD_INVALID"
    "$_CL_SLEEP" 2
    return 1
  fi

  local result
  result=$(_cl_add_project "$name" "$path")

  printf "\n"
  case "$result" in
    OK)        printf "  ✅ $_CL_MSG_ADD_OK\n     %s\n" "$name" "$path" ;;
    DUPLICATE) printf "  ⚠️  %s\n" "$_CL_MSG_ADD_DUP" ;;
    ERROR:*)   printf "  ❌ $_CL_MSG_ADD_ERR\n" "${result#ERROR:}" ;;
  esac

  "$_CL_SLEEP" 1
  return 0
}

# ─── Launch hook ─────────────────────────────────────────────────────────────
# Runs once via precmd hook after .zshrc finishes sourcing (Warp compatibility)

_cl_do_launch() {
  add-zsh-hook -d precmd _cl_do_launch 2>/dev/null

  local target="$_CL_LAUNCH_PATH"
  unset _CL_LAUNCH_PATH

  [[ -d "$target" ]] || return

  cd "$target" || return
  claude
  unset CLAUDE_LAUNCHER_SKIP
}

# ─── Main ────────────────────────────────────────────────────────────────────

_cl_main() {
  [[ ! -o interactive ]] && return 0
  [[ -n "$CLAUDE_LAUNCHER_SKIP" ]] && return 0

  if [[ -z "$_CL_PYTHON3" ]]; then
    printf "\n⚠️  %s\n\n" "$_CL_MSG_NO_PY"
    return 0
  fi

  if [[ -z "$_CL_FZF" ]]; then
    printf "\n⚠️  %s\n" "$_CL_MSG_NO_FZF"
    printf "%s\n\n" "$_CL_MSG_NO_FZF_HINT"
    return 0
  fi

  _cl_init

  # Countdown screen
  clear
  printf "╔══════════════════════════════════════════════════════╗\n"
  printf "║              Claude Code Launcher                    ║\n"
  printf "║                                                      ║\n"
  printf "║   %-49s  ║\n" "$_CL_MSG_COUNTDOWN_L1"
  printf "║   %-49s  ║\n" "$(printf "$_CL_MSG_COUNTDOWN_L2" "$_CL_TIMEOUT")"
  printf "║                                                      ║\n"
  printf "║   %-49s  ║\n" "$_CL_MSG_COUNTDOWN_TIP"
  printf "╚══════════════════════════════════════════════════════╝\n"

  local k
  if ! read -t $_CL_TIMEOUT -k 1 -s k 2>/dev/null; then
    printf "\n"
    return 0
  fi
  printf "\n"

  # fzf selection loop
  while true; do
    local sel
    sel=$(_cl_pick)

    [[ -z "$sel" ]] && break

    case "$sel" in
      "$_CL_MSG_MENU_TERMINAL")
        break
        ;;

      "$_CL_MSG_MENU_ADD")
        _cl_handle_add
        continue
        ;;

      *)
        local proj_path
        proj_path=$(printf "%s" "$sel" | "$_CL_PYTHON3" -c "
import sys
sep = chr(0x2502)
line = sys.stdin.read()
if sep in line:
    parts = line.split(sep)
    print(parts[1].strip() if len(parts) > 1 else '')
else:
    print('')
" 2>/dev/null)

        if [[ -z "$proj_path" || ! -d "$proj_path" ]]; then
          printf "\n❌ $_CL_MSG_PATH_ERR\n" "$proj_path"
          "$_CL_SLEEP" 2
          continue
        fi

        _cl_touch_project "$proj_path"
        export CLAUDE_LAUNCHER_SKIP=1
        export _CL_LAUNCH_PATH="$proj_path"
        add-zsh-hook precmd _cl_do_launch
        break
        ;;
    esac
  done
}

_cl_main
