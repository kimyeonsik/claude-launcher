#!/usr/bin/env zsh
# Claude Code Launcher - 터미널 시작 시 프로젝트 선택기
#
# 설치: ~/.zshrc 마지막에 아래 줄 추가
#   [[ -f "$HOME/.local/bin/claude-launcher" ]] && source "$HOME/.local/bin/claude-launcher"
#
# 런처 없이 터미널 열기:
#   CLAUDE_LAUNCHER_SKIP=1 zsh

_CL_CONFIG_DIR="$HOME/.config/claude-launcher"
_CL_PROJECTS_FILE="$_CL_CONFIG_DIR/projects.json"
_CL_PREVIEW_SCRIPT="$_CL_CONFIG_DIR/preview.sh"
_CL_TIMEOUT=5

# 외부 명령어 절대경로 고정 (함수 실행 시점의 PATH에 무관하게 동작)
_CL_PYTHON3=$(command -v python3 2>/dev/null)
[[ -z "$_CL_PYTHON3" && -x "/opt/homebrew/bin/python3" ]] && _CL_PYTHON3="/opt/homebrew/bin/python3"
[[ -z "$_CL_PYTHON3" && -x "/usr/local/bin/python3" ]]   && _CL_PYTHON3="/usr/local/bin/python3"
[[ -z "$_CL_PYTHON3" && -x "/usr/bin/python3" ]]          && _CL_PYTHON3="/usr/bin/python3"

_CL_FZF=$(command -v fzf 2>/dev/null)
[[ -z "$_CL_FZF" && -x "/opt/homebrew/bin/fzf" ]] && _CL_FZF="/opt/homebrew/bin/fzf"
[[ -z "$_CL_FZF" && -x "/usr/local/bin/fzf" ]]   && _CL_FZF="/usr/local/bin/fzf"

_CL_SLEEP=$(command -v sleep 2>/dev/null)
[[ -z "$_CL_SLEEP" ]] && _CL_SLEEP="/bin/sleep"

_CL_FIND=$(command -v find 2>/dev/null)
[[ -z "$_CL_FIND" ]] && _CL_FIND="/usr/bin/find"

# ─── 초기화 ───────────────────────────────────────────────────────────────────

_cl_init() {
  mkdir -p "$_CL_CONFIG_DIR"
  [[ -f "$_CL_PROJECTS_FILE" ]] || printf "[]" > "$_CL_PROJECTS_FILE"

  # fzf 미리보기 스크립트 생성 (shebang 없이 python3로 직접 실행)
  cat > "$_CL_PREVIEW_SCRIPT" << 'PREVIEW_EOF'
import sys, os, subprocess

line = sys.stdin.read().strip()
SEP = chr(0x2502)  # │

if SEP in line:
    parts = line.split(SEP)
    path = parts[1].strip() if len(parts) > 1 else ""
    if path and os.path.isdir(path):
        print(f"📁  {path}\n")
        r = subprocess.run(["ls", "-lah", path], capture_output=True, text=True)
        for l in r.stdout.splitlines()[:25]:
            print(l)
    else:
        print(f"⚠️  경로를 찾을 수 없습니다: {path!r}")
elif "일반 터미널" in line:
    print("💻  런처를 종료하고 현재 디렉토리에서 터미널을 시작합니다.")
elif "새 프로젝트" in line:
    print("➕  새 프로젝트를 목록에 추가합니다.\n")
    print("프로젝트 이름과 경로를 입력하면 projects.json에 저장됩니다.")
else:
    print(f"▶  {line}")
PREVIEW_EOF
}

# ─── JSON 조작 (Python3) ──────────────────────────────────────────────────────

# projects.json → last_used 내림차순 정렬된 라인 출력
_cl_list_projects() {
  "$_CL_PYTHON3" - "$_CL_PROJECTS_FILE" << 'PYEOF'
import json, sys

try:
    with open(sys.argv[1]) as f:
        projects = json.load(f)
    projects.sort(key=lambda p: p.get("last_used", ""), reverse=True)
    for p in projects:
        name = p.get("name", "?")
        path = p.get("path", "")
        last = p.get("last_used", "없음")
        print(f"{name:<25} \u2502 {path:<50} \u2502 {last}")
except Exception:
    pass
PYEOF
}

# 선택된 프로젝트의 last_used 현재 시각으로 갱신
_cl_touch_project() {
  local target="$1"
  "$_CL_PYTHON3" - "$_CL_PROJECTS_FILE" "$target" << 'PYEOF'
import json, sys
from datetime import datetime

try:
    with open(sys.argv[1]) as f:
        projects = json.load(f)
    for p in projects:
        if p.get("path") == sys.argv[2]:
            p["last_used"] = datetime.now().strftime("%Y-%m-%dT%H:%M:%S")
    with open(sys.argv[1], "w") as f:
        json.dump(projects, f, indent=2, ensure_ascii=False)
except Exception:
    pass
PYEOF
}

# 새 프로젝트 추가
_cl_add_project() {
  local name="$1" path="$2"
  "$_CL_PYTHON3" - "$_CL_PROJECTS_FILE" "$name" "$path" << 'PYEOF'
import json, sys
from datetime import datetime

file, name, path = sys.argv[1], sys.argv[2], sys.argv[3]
try:
    with open(file) as f:
        data = json.load(f)
    for p in data:
        if p.get("path") == path:
            print("DUPLICATE")
            sys.exit(0)
    data.append({
        "name": name,
        "path": path,
        "last_used": datetime.now().strftime("%Y-%m-%dT%H:%M:%S")
    })
    with open(file, "w") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)
    print("OK")
except Exception as e:
    print(f"ERROR:{e}")
PYEOF
}

# 프로젝트 제거
_cl_remove_project() {
  local target="$1"
  "$_CL_PYTHON3" - "$_CL_PROJECTS_FILE" "$target" << 'PYEOF'
import json, sys

try:
    with open(sys.argv[1]) as f:
        data = json.load(f)
    data = [p for p in data if p.get("path") != sys.argv[2]]
    with open(sys.argv[1], "w") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)
    print("OK")
except Exception as e:
    print(f"ERROR:{e}")
PYEOF
}

# ─── UI ──────────────────────────────────────────────────────────────────────

# fzf 프로젝트 선택기 실행 → 선택 항목 반환
_cl_pick() {
  local list
  list=$(_cl_list_projects)

  {
    echo "[→ 일반 터미널로]"
    echo "[+ 새 프로젝트 추가]"
    [[ -n "$list" ]] && printf "%s\n" "$list"
  } | "$_CL_FZF" \
    --header=" Claude Code Launcher │ Enter:선택  Esc:종료" \
    --preview="echo {} | \"$_CL_PYTHON3\" \"$_CL_PREVIEW_SCRIPT\"" \
    --preview-window="right:50%:wrap" \
    --height="80%" \
    --border="rounded" \
    --prompt="▶ " \
    --pointer="→" \
    --no-sort \
    --ansi
}

# fzf 디렉토리 탐색기 → 선택한 절대 경로 반환
_cl_browse_dir() {
  local start="${1:-$HOME}"
  "$_CL_FIND" "$start" -maxdepth 5 -type d \
    \( -name ".git" -o -name "node_modules" -o -name ".cache" \
       -o -name ".Trash" -o -name "__pycache__" -o -name ".venv" \
       -o -name "venv" -o -name ".hg" \) -prune \
    -o -type d -print 2>/dev/null | \
  "$_CL_FZF" \
    --header=" 디렉토리 탐색 │ 타이핑으로 필터  Enter:선택  Esc:취소" \
    --preview="ls -lah {}" \
    --preview-window="right:50%:wrap" \
    --height="80%" \
    --border="rounded" \
    --prompt="📁 " \
    --pointer="→"
}

# 새 프로젝트 추가 인터랙션
_cl_handle_add() {
  printf "\n"
  printf "┌─ 새 프로젝트 추가 ─────────────────────────────────┐\n"
  printf "│                                                    │\n"

  local name path

  printf "│  이름: "
  read -r name < /dev/tty

  if [[ -z "$name" ]]; then
    printf "│  ❌ 이름을 입력해야 합니다.\n"
    printf "└────────────────────────────────────────────────────┘\n"
    "$_CL_SLEEP" 1
    return 1
  fi

  # fzf 디렉토리 탐색기로 경로 선택
  printf "│  경로를 탐색하여 선택하세요...\n"
  printf "└────────────────────────────────────────────────────┘\n"

  path=$(_cl_browse_dir)

  # ESC 또는 선택 취소
  if [[ -z "$path" ]]; then
    printf "\n  취소되었습니다.\n"
    "$_CL_SLEEP" 1
    return 1
  fi

  # 상대 경로 → 절대 경로 변환
  path=$(cd "$path" 2>/dev/null && pwd)

  if [[ -z "$path" || ! -d "$path" ]]; then
    printf "\n  ❌ 유효하지 않은 경로입니다.\n"
    "$_CL_SLEEP" 2
    return 1
  fi

  local result
  result=$(_cl_add_project "$name" "$path")

  printf "\n"
  case "$result" in
    OK)        printf "  ✅ '%s' 추가됨\n     %s\n" "$name" "$path" ;;
    DUPLICATE) printf "  ⚠️  이미 등록된 경로입니다.\n" ;;
    ERROR:*)   printf "  ❌ 오류: %s\n" "${result#ERROR:}" ;;
  esac

  "$_CL_SLEEP" 1
  return 0
}

# ─── 런처 실행 훅 ────────────────────────────────────────────────────────────
# .zshrc 소스 완료 직후 precmd 훅으로 한 번만 실행 → Warp 타임아웃 방지

_cl_do_launch() {
  # 훅에서 자기 자신 제거 (한 번만 실행)
  add-zsh-hook -d precmd _cl_do_launch 2>/dev/null

  local target="$_CL_LAUNCH_PATH"
  unset _CL_LAUNCH_PATH

  [[ -d "$target" ]] || return

  cd "$target" || return
  claude
  unset CLAUDE_LAUNCHER_SKIP
}

# ─── 메인 ────────────────────────────────────────────────────────────────────

_cl_main() {
  # 비인터랙티브 쉘 (스크립트, cron 등) 무시
  [[ ! -o interactive ]] && return 0
  # 재귀 방지: claude 실행 후 내부 서브쉘 등
  [[ -n "$CLAUDE_LAUNCHER_SKIP" ]] && return 0

  # Python3 없으면 조용히 종료
  if [[ -z "$_CL_PYTHON3" ]]; then
    printf "\n⚠️  Claude Launcher: python3를 찾을 수 없습니다.\n\n"
    return 0
  fi

  # fzf 없으면 안내 후 종료
  if [[ -z "$_CL_FZF" ]]; then
    printf "\n⚠️  Claude Launcher: fzf가 설치되어 있지 않습니다.\n"
    printf "   설치: brew install fzf\n\n"
    return 0
  fi

  _cl_init

  # ── 카운트다운 화면 ──
  clear
  printf "╔══════════════════════════════════════════════════════╗\n"
  printf "║              Claude Code Launcher                    ║\n"
  printf "║                                                      ║\n"
  printf "║   아무 키나 누르면 프로젝트 목록이 표시됩니다.       ║\n"
  printf "║   %d초 후 일반 터미널로 자동 전환됩니다.             ║\n" "$_CL_TIMEOUT"
  printf "║                                                      ║\n"
  printf "║   팁: CLAUDE_LAUNCHER_SKIP=1 zsh 으로 바로 열기      ║\n"
  printf "╚══════════════════════════════════════════════════════╝\n"

  # 키 입력 대기 (타임아웃 시 일반 터미널)
  local k
  if ! read -t $_CL_TIMEOUT -k 1 -s k 2>/dev/null; then
    printf "\n"
    return 0
  fi
  printf "\n"

  # ── fzf 선택 루프 (새 프로젝트 추가 후 재선택 지원) ──
  while true; do
    local sel
    sel=$(_cl_pick)

    # ESC 또는 Ctrl+C → 일반 터미널
    [[ -z "$sel" ]] && break

    case "$sel" in
      "[→ 일반 터미널로]")
        break
        ;;

      "[+ 새 프로젝트 추가]")
        _cl_handle_add
        continue
        ;;

      *)
        # │ 기준으로 두 번째 필드(경로) 추출
        local proj_path
        proj_path=$(printf "%s" "$sel" | "$_CL_PYTHON3" -c "
import sys
sep = chr(0x2502)
line = sys.stdin.read()
if sep in line:
    parts = line.split(sep)
    print(parts[1].strip() if len(parts) > 1 else '')
else:
    print('')
" 2>/dev/null)

        if [[ -z "$proj_path" || ! -d "$proj_path" ]]; then
          printf "\n❌ 경로를 찾을 수 없습니다: '%s'\n" "$proj_path"
          "$_CL_SLEEP" 2
          continue
        fi

        # 선택 확정: last_used 갱신 → precmd 훅으로 .zshrc 완료 후 자동 실행
        _cl_touch_project "$proj_path"
        export CLAUDE_LAUNCHER_SKIP=1
        export _CL_LAUNCH_PATH="$proj_path"
        add-zsh-hook precmd _cl_do_launch
        break
        ;;
    esac
  done
}

_cl_main
